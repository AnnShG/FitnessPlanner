<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_page_background_colour"
    android:fillViewport="true"
    tools:context=".logic.exercise.ExerciseDetailFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="40dp">

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guidelineLeft"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="@dimen/guideline_left_percent" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guidelineRight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="@dimen/guideline_right_percent" />

        <ImageButton
            android:id="@+id/backButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginTop="25dp"

            android:background="@android:color/transparent"
            android:contentDescription="@string/back_button"
            android:padding="4dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/text_black_colour"

            app:layout_constraintStart_toStartOf="@id/guidelineLeft"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/exerciseTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"

            android:fontFamily="@font/lexend_font"
            android:gravity="center"
            android:text="@string/exercise_item_title"
            android:textColor="@color/text_black_colour"
            android:textSize="24sp"
            android:textStyle="bold"

            app:layout_constraintBottom_toBottomOf="@id/backButton"
            app:layout_constraintStart_toEndOf="@id/backButton"
            app:layout_constraintEnd_toStartOf="@id/editExerciseButton"
            app:layout_constraintTop_toTopOf="@id/backButton"/>

        <ImageView
            android:id="@+id/editExerciseButton"
            android:layout_width="28dp"
            android:layout_height="28dp"

            app:srcCompat="@drawable/ic_edit_field"
            app:tint="@color/workout_left_side_control_icons_colour"

            app:layout_constraintBottom_toBottomOf="@id/backButton"
            app:layout_constraintEnd_toEndOf="@id/guidelineRight"
            app:layout_constraintTop_toTopOf="@id/backButton"/>


        <FrameLayout
            android:id="@+id/mediaContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:minHeight="200dp"
            app:layout_constraintEnd_toEndOf="@id/guidelineRight"
            app:layout_constraintStart_toStartOf="@id/guidelineLeft"
            app:layout_constraintTop_toBottomOf="@id/exerciseTitle">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/mainExerciseImage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:adjustViewBounds="true"
                android:scaleType="fitCenter"
                android:maxHeight="300dp"
                app:shapeAppearanceOverlay="@style/RoundedCorners"
                tools:srcCompat="@drawable/sample_exercise" />

            <VideoView
                android:id="@+id/mainExerciseVideo"
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:layout_gravity="center"
                android:visibility="gone" />

        </FrameLayout>

        <TextView
            android:id="@+id/categoryLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"

            android:fontFamily="@font/lexend_font"
            android:text="@string/exercise_item_category_label"
            android:textColor="@color/text_black_colour"
            android:textSize="18sp"
            android:textStyle="bold"

            app:layout_constraintStart_toStartOf="@id/guidelineLeft"
            app:layout_constraintTop_toBottomOf="@id/mediaContainer" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/primaryCategoryChipGroup"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"

            android:layout_marginTop="8dp"
            app:chipSpacingHorizontal="8dp"

            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/categoryLabel" />

        <TextView
            android:id="@+id/exerciseDescriptionLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"

            android:fontFamily="@font/lexend_font"
            android:text="@string/exercise_item_description_label"
            android:textColor="@color/text_black_colour"
            android:textSize="18sp"
            android:textStyle="bold"

            app:layout_constraintStart_toStartOf="@id/guidelineLeft"
            app:layout_constraintTop_toBottomOf="@id/primaryCategoryChipGroup" />

        <TextView
            android:id="@+id/exerciseDescriptionText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"

            android:fontFamily="@font/lexend_font"
            android:text="@string/exercise_item_description_text"
            android:textColor="@color/text_black_colour"
            android:textSize="16sp"

            app:layout_constraintEnd_toEndOf="@id/guidelineRight"
            app:layout_constraintStart_toStartOf="@id/guidelineLeft"
            app:layout_constraintTop_toBottomOf="@id/exerciseDescriptionLabel" />

        <TextView
            android:id="@+id/stepsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"

            android:fontFamily="@font/lexend_font"
            android:text="@string/exercise_item_steps_label"
            android:textColor="@color/text_black_colour"
            android:textSize="18sp"
            android:textStyle="bold"

            app:layout_constraintStart_toStartOf="@id/guidelineLeft"
            app:layout_constraintTop_toBottomOf="@id/exerciseDescriptionText" />

        <LinearLayout
            android:id="@+id/stepsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            app:layout_constraintTop_toBottomOf="@id/stepsTitle" />

        <TextView
            android:id="@+id/exerciseNotesLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"

            android:fontFamily="@font/lexend_font"
            android:text="@string/exercise_item_notes_label"
            android:textColor="@color/text_black_colour"
            android:textSize="18sp"
            android:textStyle="bold"

            app:layout_constraintStart_toStartOf="@id/guidelineLeft"
            app:layout_constraintTop_toBottomOf="@id/stepsContainer" />

        <TextView
            android:id="@+id/exerciseNotesText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"

            android:fontFamily="@font/lexend_font"
            android:text="@string/exercise_item_notes_text"
            android:textColor="@color/text_black_colour"
            android:textSize="16sp"

            app:layout_constraintEnd_toEndOf="@id/guidelineRight"
            app:layout_constraintStart_toStartOf="@id/guidelineLeft"
            app:layout_constraintTop_toBottomOf="@id/exerciseNotesLabel" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>